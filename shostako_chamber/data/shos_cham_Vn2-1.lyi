    cis) r r4 r2
    R1
    <<
        {
            \override MultiMeasureRest.staff-position = #-8
            R1*2
            \revert MultiMeasureRest.staff-position
            r2 \cueClefUnset b_\markup{\dynamic "mf" \italic "espr."} 
        }
        \new CueVoice{
            \cueClef alto \stemUp b1^"Viola"~
            b4 bes---. a---. e---.
            a2 s
        }
    >> 
    c2\< aes!~
    aes\f g_\markup{\italic "dim."}
    g1~
    g2 g 
    % 2
    <<
        {
            g1\pp~
            \repeat unfold 15 g1~
            g\>~
            \stemDown g8\! \stemNeutral r r4 r2
        }
        \new CueVoice {
            \voiceOne{
                e''4\rest ees^"Vn1 solo"( d des)
                c( b bes a)
                aes2. ( g4)
                e'\rest aes,( a bes)
                b( c aes! c)
                fes2.( ees4)
                d2\rest aes4( ces
                ees2. d4)
                c!( bes aes g)
                fis( g des fes)
                aes2.( g4)
                d'\rest bes( aes g)
                d'\rest bes( aes g)
                fis( g bes, des)
                f!2.( fes4)
                ees2.( c4)
                d'\rest e,( ees c)
                des2.( c4)
            }
        }
    >>
    % 3
    R1*2
    \pageBreak
    <<
        {
        \override MultiMeasureRest.staff-position = #-8
        R1*2
        \revert MultiMeasureRest.staff-position
        }
        \new CueVoice{
        \stemUp d'2^"Vn1 solo"( ees4 d)
        f(ees d c)
        }
    >> 
    g,1\pp~
    g 
    c2_\markup{\italic "poco espr."}( g4-- g--)
    aes2( g)
    aes2\>( g)
    % 4
    c2\pp( g4-- g--)
    aes2( g)
    des'2( aes4-- aes--)
    bes2.( c4)
    des2( c4 d)
    ees2( c)
    ees2( des4 ees)
    e2( c~
    c) g4--( g--)
    aes2( g)
    des'2( aes4-- aes--)
    bes2( aes)
    g( a4-- a--)
    c2\<( b)
    ees\!( d!)
    aes'\>( g~
    % 5
    g\pp) g,4--( g--)
    aes2( g)
    f'2( c4-- c--)
    des2( c)
    ees2( des4 ees)
    fes2( des~
    des) c4( des
    ees2 c)
    % 6
    b1\upbow_\markup{\italic "espr. e cresc."}
    bes! 
    a 
    aes!\mf\>( 
    g)
    g\p\>
    g2 g 
    % 7
    a\pp g4--( g--)
    c1~
    c~
    c4 b\<( c d)
    c1\>~
    c2\! cis 
    << {fis1~(} {s2 s_\markup{\italic "cresc."}}>>
    fis1~
    fis2._\markup{\italic "dim."} g4) \breathe
    % 8
    <g e'>2\pp^"div."( <a f'>)
    <<{e'2( d~ d)} \\ {g,1~ g2} >>
    <f c'>2~
    q <e b'>2~
    <d b'> <c c'>
    << {cis'1 b2( a)} \\ {cis,1~ cis}>>
    r4 b\<^"unis."( cis d~)
    d1\>
    % 9 
