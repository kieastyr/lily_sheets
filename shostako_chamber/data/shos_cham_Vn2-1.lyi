            \revert MultiMeasureRest.staff-position
            r2 \cueClefUnset d2\p 
        }
        \new CueVoice{
            \cueClef alto \stemUp r2 a^"Viola" bes s
        }
    >>
    ees c 
    b2.( c4)
    c1~
    c2 des 
    d!1
    c~
    c~
    c4\>~ c8\! r d2_\markup{\italic "dim."}
    ees c 
    % 1
    b1\pp\<
    e2\>( ees~
    ees\!) d2^"soli"_\markup{\italic "poco espr."}
    ees c~\<
    c4.\mp d8( b4.) c8(
