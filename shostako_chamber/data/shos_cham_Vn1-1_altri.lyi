\relative c'{
    s1*26
    c1^"altri"
    g2 g
    <<
        {
            <<
                {g1\pp~} 
                {
                    \once \hide MultiMeasureRest 
                    R1^\markup{\tiny \number "1 - 17"}
                }
            >>
            \repeat unfold 15 g1~
            g\>~
        }
        {
            \set countPercentRepeats = ##t
            \hide PercentRepeat
            \repeat percent 17 { s1 }
        }
    >>
    g8\! r r4 r2
    R1*7
}